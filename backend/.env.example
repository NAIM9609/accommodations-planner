# Backend environment variables for local development
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to source control.
#
# These variables are set automatically by the Lambda runtime in AWS.
# For local testing, export them in your shell or use a tool like direnv.
#
# Usage (LocalStack — full stack):
#   docker compose up -d          # starts LocalStack + deploys everything
#   cd frontend && npm run dev    # frontend works immediately at http://localhost:3000
#
# Usage (unit tests — no AWS needed):
#   npm test                      # DynamoDB is fully mocked by jest
#
# See README.md → Local Development for full instructions.

AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=accommodations-planner-dev-reservations
ENVIRONMENT=dev

# Set DYNAMODB_ENDPOINT when running LocalStack locally.
# Leave unset (or remove) when deploying to AWS Lambda.
DYNAMODB_ENDPOINT=http://localhost:4566
