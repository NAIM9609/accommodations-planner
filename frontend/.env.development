# Loaded automatically by `npm run dev`.
# Points to the LocalStack API Gateway started by `docker compose up`.
# The deploy service writes the exact URL to frontend/.env.local (gitignored)
# which takes precedence; this file provides the stable fallback when the
# custom API Gateway ID (aplocal) is in use.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4566/restapis/aplocal/dev/_user_request_
NEXT_PUBLIC_STAGE=dev
